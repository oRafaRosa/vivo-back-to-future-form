{
  "formTitle": "Inscrição de Projetos | Back to the Future",
  "sourceDocument": "Atualizacao Formulario Projetos.docx",
  "steps": [
    {
      "id": "identification",
      "title": "Identificação",
      "description": "Informe nome, área, líder e coparticipantes.",
      "fields": [
        {
          "id": "projectName",
          "label": "Nome do Projeto",
          "type": "text",
          "required": true,
          "maxLength": 80
        },
        {
          "id": "responsibleArea",
          "label": "Área Responsável",
          "type": "select",
          "required": true,
          "options": [
            "Gerência de Serviços ao Cliente Centralizado",
            "Qualidade",
            "Produção",
            "Projetos e TI",
            "Processos"
          ]
        },
        {
          "id": "projectLeader",
          "label": "Líder do Projeto",
          "type": "text",
          "required": true,
          "maxLength": 60
        },
        {
          "id": "leaderEmail",
          "label": "E-mail do líder",
          "type": "email",
          "required": true
        },
        {
          "id": "coParticipants",
          "label": "Coparticipantes",
          "type": "dynamic-participants",
          "required": false,
          "maxLength": 300,
          "participantFields": [
            {
              "id": "name",
              "label": "Nome ou equipe",
              "type": "text",
              "required": true,
              "maxLength": 60
            },
            {
              "id": "email",
              "label": "E-mail, se houver",
              "type": "email",
              "required": false
            }
          ]
        }
      ]
    },
    {
      "id": "project",
      "title": "Projeto",
      "description": "Detalhe objetivo, descrição e ganho financeiro.",
      "fields": [
        {
          "id": "hasFinancialGain",
          "label": "O projeto possui ganho financeiro?",
          "type": "boolean",
          "required": true
        },
        {
          "id": "financialGainDescription",
          "label": "Descreva o ganho financeiro",
          "type": "textarea",
          "requiredWhen": "hasFinancialGain === true",
          "maxLength": 300
        },
        {
          "id": "projectObjective",
          "label": "Objetivo do Projeto",
          "type": "textarea",
          "required": true,
          "maxLength": 500
        },
        {
          "id": "projectDescription",
          "label": "Descrição do Projeto",
          "type": "textarea",
          "required": true,
          "maxLength": 2000
        }
      ]
    },
    {
      "id": "strategic-impact",
      "title": "Impacto estratégico",
      "description": "Informe impactos, AS IS e TO BE.",
      "fields": [
        {
          "id": "strategicImpacts",
          "label": "Impacto Estratégico",
          "type": "checkbox",
          "required": true,
          "options": [
            "Produtividade",
            "Qualidade",
            "Eficiência",
            "Processos",
            "Experiência do Cliente",
            "IA",
            "Automação"
          ]
        },
        {
          "id": "currentSituation",
          "label": "Situação Atual (AS IS)",
          "type": "textarea",
          "required": true,
          "maxLength": 700
        },
        {
          "id": "futureSituation",
          "label": "Situação Futura (TO BE)",
          "type": "textarea",
          "required": true,
          "maxLength": 700
        }
      ]
    },
    {
      "id": "results",
      "title": "Benefícios e resultados",
      "description": "Informe benefícios, produtos impactados, premissas e resultados esperados.",
      "fields": [
        {
          "id": "projectBenefits",
          "label": "Benefícios do Projeto",
          "type": "textarea",
          "required": true,
          "maxLength": 700
        },
        {
          "id": "impactedProducts",
          "label": "Produtos Impactados",
          "type": "checkbox",
          "required": true,
          "options": [
            "Cobre",
            "Fibra",
            "Móvel",
            "Voz – TDM (v5)",
            "Voz – TDM (h248)",
            "Voz – IMS (V5.2)",
            "Voz – IMS (H248)",
            "Voz – IMS",
            "Voip/SIP",
            "Projetos especiais",
            "Banda Larga Fibra",
            "Banda Larga Cobre",
            "B2B Dados Avançado",
            "Pré-Pago",
            "Pós-pago",
            "Controle",
            "Híbrida",
            "DTH",
            "IPTV",
            "B2C",
            "B2B",
            "Atacado"
          ]
        },
        {
          "id": "assumptions",
          "label": "Premissas",
          "type": "textarea",
          "required": false,
          "maxLength": 500
        },
        {
          "id": "expectedResults",
          "label": "Resultados Esperados",
          "type": "textarea",
          "required": true,
          "maxLength": 700
        }
      ]
    },
    {
      "id": "evidence",
      "title": "Evidências",
      "description": "Informe o link da pasta compartilhada no OneDrive.",
      "fields": [
        {
          "id": "oneDriveFolderLink",
          "label": "Link da pasta compartilhada no OneDrive",
          "type": "url",
          "required": true,
          "description": "Crie uma pasta no OneDrive com vídeo, apresentação e evidências. Compartilhe a pasta e cole o link no formulário."
        }
      ]
    }
  ]
}
