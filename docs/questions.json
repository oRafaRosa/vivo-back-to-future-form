{
  "formTitle": "Inscrição de Projetos | Back to the Future",
  "sourceDocument": "Atualizacao Formulario Projetos.docx",
  "steps": [
    {
      "id": "identification",
      "title": "Identificação",
      "description": "Informe nome, área, líder e coparticipantes.",
      "fields": [
        {
          "id": "projectName",
          "label": "Nome do Projeto",
          "type": "text",
          "required": true,
          "maxLength": 80
        },
        {
          "id": "responsibleArea",
          "label": "Área Responsável",
          "type": "select",
          "required": true,
          "options": [
            "Gerência de Serviços ao Cliente Centralizado",
            "Operações FTTH",
            "Qualidade",
            "MIS / Analytics",
            "Atendimento",
            "Outra área"
          ]
        },
        {
          "id": "projectLeader",
          "label": "Líder do Projeto",
          "type": "text",
          "required": true,
          "maxLength": 60
        },
        {
          "id": "leaderEmail",
          "label": "E-mail do líder",
          "type": "email",
          "required": true
        },
        {
          "id": "coParticipants",
          "label": "Coparticipantes",
          "type": "dynamic-participants",
          "required": false,
          "maxLength": 300,
          "participantFields": [
            {
              "id": "name",
              "label": "Nome ou equipe",
              "type": "text",
              "required": true,
              "maxLength": 60
            },
            {
              "id": "email",
              "label": "E-mail, se houver",
              "type": "email",
              "required": false
            }
          ]
        }
      ]
    },
    {
      "id": "project",
      "title": "Projeto",
      "description": "Detalhe objetivo, descrição e ganho financeiro.",
      "fields": [
        {
          "id": "hasFinancialGain",
          "label": "O projeto possui ganho financeiro?",
          "type": "boolean",
          "required": true
        },
        {
          "id": "financialGainDescription",
          "label": "Descreva o ganho financeiro",
          "type": "textarea",
          "requiredWhen": "hasFinancialGain === true",
          "maxLength": 300
        },
        {
          "id": "projectObjective",
          "label": "Objetivo do Projeto",
          "type": "textarea",
          "required": true,
          "maxLength": 500
        },
        {
          "id": "projectDescription",
          "label": "Descrição do Projeto",
          "type": "textarea",
          "required": true,
          "maxLength": 2000
        }
      ]
    },
    {
      "id": "strategic-impact",
      "title": "Impacto estratégico",
      "description": "Informe impactos, AS IS e TO BE.",
      "fields": [
        {
          "id": "strategicImpacts",
          "label": "Impacto Estratégico",
          "type": "checkbox",
          "required": true,
          "options": [
            "Produtividade",
            "Eficiência Operacional",
            "IA",
            "Automação",
            "Experiência do Cliente",
            "Ganho financeiro",
            "Qualidade",
            "Escalabilidade"
          ]
        },
        {
          "id": "currentSituation",
          "label": "Situação Atual (AS IS)",
          "type": "textarea",
          "required": true,
          "maxLength": 700
        },
        {
          "id": "futureSituation",
          "label": "Situação Futura (TO BE)",
          "type": "textarea",
          "required": true,
          "maxLength": 700
        }
      ]
    },
    {
      "id": "results",
      "title": "Benefícios e resultados",
      "description": "Informe benefícios, produtos impactados, premissas e resultados esperados.",
      "fields": [
        {
          "id": "projectBenefits",
          "label": "Benefícios do Projeto",
          "type": "textarea",
          "required": true,
          "maxLength": 700
        },
        {
          "id": "impactedProducts",
          "label": "Produtos Impactados",
          "type": "checkbox",
          "required": true,
          "options": ["Fibra", "IPTV", "Voz IMS", "B2B", "B2C", "Móvel", "Outros"]
        },
        {
          "id": "assumptions",
          "label": "Premissas",
          "type": "textarea",
          "required": false,
          "maxLength": 500
        },
        {
          "id": "expectedResults",
          "label": "Resultados Esperados",
          "type": "textarea",
          "required": true,
          "maxLength": 700
        }
      ]
    },
    {
      "id": "evidence",
      "title": "Evidências",
      "description": "Anexe vídeo obrigatório e materiais complementares.",
      "fields": [
        {
          "id": "projectVideo",
          "label": "Upload do Vídeo",
          "type": "file",
          "required": true,
          "accept": ["video/mp4", "video/quicktime", "video/x-msvideo", "video/webm"],
          "rule": "Vídeo de até 3 minutos"
        },
        {
          "id": "presentation",
          "label": "Apresentação PowerPoint",
          "type": "file",
          "required": false,
          "accept": [
            "application/vnd.openxmlformats-officedocument.presentationml.presentation",
            "application/vnd.ms-powerpoint"
          ]
        },
        {
          "id": "additionalEvidence",
          "label": "Outras evidências/resultados",
          "type": "multi-file",
          "required": false
        }
      ]
    }
  ]
}
